# Solana RPC endpoint
# Mainnet: https://api.mainnet-beta.solana.com
# Gunakan private RPC untuk produksi (Helius, QuickNode, dll.)
RPC_ENDPOINT=https://api.mainnet-beta.solana.com

# Private key wallet dalam format base58
# PERINGATAN: Jangan pernah commit private key asli!
WALLET_PRIVATE_KEY=your_base58_private_key_here

# Alamat pool Meteora DLMM yang mau di-manage
POOL_ADDRESS=your_meteora_dlmm_pool_address_here

# Tipe strategi LP (Spot | Curve | BidAsk)
STRATEGY_TYPE=Spot

# Jumlah bin di setiap sisi dari active bin
BIN_RANGE=10

# Interval cek rebalance dalam milidetik (default: 30 detik)
REBALANCE_CHECK_INTERVAL_MS=30000

# Minimum bin keluar range sebelum trigger rebalance
REBALANCE_THRESHOLD_BINS=1

# Interval klaim fee dalam milidetik (default: 1 jam)
FEE_CLAIM_INTERVAL_MS=3600000

# Minimum nilai USD fee yang belum diklaim sebelum auto-claim
FEE_CLAIM_THRESHOLD_USD=1.0

# Token Telegram Bot (dari @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Chat ID Telegram untuk kirim notifikasi
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Slippage tolerance dalam basis points (100 = 1%)
SLIPPAGE_BPS=100

# Jumlah token X yang di-deposit (dalam unit terkecil, contoh: lamports untuk SOL)
# Kosongkan untuk pakai semua saldo yang tersedia
DEPOSIT_AMOUNT_X=

# Jumlah token Y yang di-deposit
# Kosongkan untuk pakai semua saldo yang tersedia
DEPOSIT_AMOUNT_Y=

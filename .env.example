# ── Wallet ────────────────────────────────────────────────────────────────────
WALLET_PRIVATE_KEY=your_base58_private_key_here

# ── Solana RPC ─────────────────────────────────────────────────────────────────
RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key_here
FALLBACK_RPC_URL=                         # optional — public RPC fallback when Helius is down

# ── Devnet Testing (T22) ────────────────────────────────────────────────────────
# Set SOLANA_NETWORK=devnet to route ALL RPC calls to devnet (for T22 testing).
# Fund the devnet wallet via https://faucet.solana.com before running cycles.
# IMPORTANT: Use a separate devnet wallet — never your mainnet wallet key.
SOLANA_NETWORK=                           # set to "devnet" to enable devnet mode
HELIUS_DEVNET_RPC_URL=https://devnet.helius-rpc.com/?api-key=your_helius_api_key_here

# ── LLM Provider ──────────────────────────────────────────────────────────────
# DeepSeek V4 Pro for screening/management, V4 Flash for general queries
DEEPSEEK_API_KEY=sk-your_deepseek_api_key_here

# ── API Keys ───────────────────────────────────────────────────────────────────
HELIUS_API_KEY=your_helius_api_key_here
LPAGENT_API_KEY=your_lpagent_api_key_here
BIRDEYE_API_KEY=                          # optional — enables whale concentration + price momentum
DEXSCREENER_API_KEY=                      # optional — enables token age + trending signal

# ── Telegram Notifications (optional) ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALLOWED_USER_IDS=

# ── Dangerous admin actions (disabled by default) ─────────────────────────────
ALLOW_SELF_UPDATE=false

# ── Misc ───────────────────────────────────────────────────────────────────────
DRY_RUN=true
LOG_LEVEL=info
